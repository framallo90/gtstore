# Required (local dev and Docker)
# Use strong secrets in real environments.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="geekytreasures"

# Used by Prisma + local `nx serve api` when connecting from your host machine.
# Note: this repo maps Docker Postgres to host port 5433 to avoid conflicts with local Postgres installs.
# Also prefer 127.0.0.1 over localhost to avoid IPv6/portproxy edge cases on Windows.
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5433/DB?schema=public"

# Auth (required)
JWT_ACCESS_SECRET="CHANGE_ME"
JWT_REFRESH_SECRET="CHANGE_ME"

# Admin seed user (optional - if not set, seed will skip admin creation)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE_ME"

# Optional
PORT=3000
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
CORS_ORIGINS="http://localhost:4200,http://localhost:4300"
# Express trust proxy setting. Secure default is 0.
# Use 1 (or strict hop count) only when running behind nginx/reverse-proxy that sanitizes forwarded headers.
TRUST_PROXY=0
# Production safety flags for reverse proxy mode.
EXPECT_REVERSE_PROXY=0
PROXY_SANITIZES_XFF=0
# Swagger (opcional). Default: habilitado en dev y deshabilitado en production si esta vacio.
SWAGGER_ENABLED=""
SWAGGER_PRODUCTION_ALLOWED=0

# Emails transaccionales (opcional)
# Default: solo loguea (no envia). Para envio real configura SMTP y EMAIL_FROM.
EMAIL_DRIVER="log" # log | smtp
EMAIL_FROM="GeekyTreasures <noreply@example.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# Mercado Pago (Checkout Pro) - opcional
# IMPORTANTE: MP_ACCESS_TOKEN es secreto (solo backend).
MP_ACCESS_TOKEN=""
# sandbox | production
MP_ENV="sandbox"
MP_CURRENCY_ID="USD"
# Base publica del storefront para links (emails + back_urls de Mercado Pago)
STORE_BASE_URL="http://localhost:4200"
# URL publica del webhook (debe ser accesible desde internet en prod)
MP_NOTIFICATION_URL=""
# Secret de firma del webhook de Mercado Pago (opcional pero recomendado en prod)
MP_WEBHOOK_SECRET=""

# Docker Compose secret file paths (optional override).
# By default docker-compose.yml uses ./.secrets/*.example files.
POSTGRES_PASSWORD_PATH=""
JWT_ACCESS_SECRET_PATH=""
JWT_REFRESH_SECRET_PATH=""
MP_ACCESS_TOKEN_PATH=""
MP_WEBHOOK_SECRET_PATH=""

# Andreani (cotizacion de envio) - opcional
# Si no lo activas, el checkout funciona sin sumar envio.
ANDREANI_ENABLED="false"
ANDREANI_USERNAME=""
ANDREANI_PASSWORD=""
ANDREANI_SENDER_CONTRACT=""
ANDREANI_SENDER_CLIENT=""
ANDREANI_SENDER_PROVINCE=""
ANDREANI_SENDER_DISTRICT=""
ANDREANI_SENDER_LOCALITY=""
ANDREANI_SENDER_ZIP_CODE=""
# Opcionales de ajuste
ANDREANI_RECEIVER_PROVINCE=""
ANDREANI_RECEIVER_DISTRICT=""
ANDREANI_RECEIVER_LOCALITY=""
ANDREANI_SOURCE_COUNTRY="AR"
ANDREANI_RECEIVER_COUNTRY="AR"
ANDREANI_PRODUCT_TYPE="LIBROS"
ANDREANI_DEFAULT_WEIGHT_GRAMS="500"
ANDREANI_DEFAULT_HEIGHT_CM="25"
ANDREANI_DEFAULT_WIDTH_CM="18"
ANDREANI_DEFAULT_DEPTH_CM="4"
ANDREANI_MIN_WEIGHT_KG="0.1"
ANDREANI_TIMEOUT_MS="8000"
ANDREANI_TOKEN_TTL_MS="72000000"
