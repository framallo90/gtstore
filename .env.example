# Required (local dev and Docker)
# Use strong secrets in real environments.
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="CHANGE_ME"
POSTGRES_DB="geekytreasures"

# Used by Prisma + local `nx serve api` when connecting from your host machine.
# Note: this repo maps Docker Postgres to host port 5433 to avoid conflicts with local Postgres installs.
# Also prefer 127.0.0.1 over localhost to avoid IPv6/portproxy edge cases on Windows.
DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5433/DB?schema=public"

# Auth (required)
JWT_ACCESS_SECRET="CHANGE_ME"
JWT_REFRESH_SECRET="CHANGE_ME"

# Admin seed user (optional - if not set, seed will skip admin creation)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="CHANGE_ME"

# Optional: force prisma seed execution at container start (Dockerfile.api). Use "1" for local/first-run only.
RUN_SEED="0"

# Optional
PORT=3000
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
CORS_ORIGINS="http://localhost:4200,http://localhost:4300"
# Express trust proxy setting. Use 1 when running behind nginx/reverse-proxy, 0 when exposing the API directly.
TRUST_PROXY=1
# Swagger (opcional). Default: habilitado en dev y deshabilitado en production si esta vacio.
SWAGGER_ENABLED=""

# Emails transaccionales (opcional)
# Default: solo loguea (no envia). Para envio real configura SMTP y EMAIL_FROM.
EMAIL_DRIVER="log" # log | smtp
EMAIL_FROM="GeekyTreasures <noreply@example.com>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""

# Mercado Pago (Checkout Pro) - opcional
# IMPORTANTE: MP_ACCESS_TOKEN es secreto (solo backend).
MP_ACCESS_TOKEN=""
# sandbox | production
MP_ENV="sandbox"
MP_CURRENCY_ID="USD"
# Base publica del storefront para links (emails + back_urls de Mercado Pago)
STORE_BASE_URL="http://localhost:4200"
# URL publica del webhook (debe ser accesible desde internet en prod)
MP_NOTIFICATION_URL=""
# Secret de firma del webhook de Mercado Pago (opcional pero recomendado en prod)
MP_WEBHOOK_SECRET=""
