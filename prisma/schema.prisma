// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

enum SellerStatus {
  NONE
  PENDING_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum SellerVerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum ProductType {
  BOOK
  COMIC
}

enum MarketplaceListingCategory {
  COMIC
  MANGA
  BOOK
  COLLECTOR_VOLUME
}

enum MarketplaceListingStatus {
  DRAFT
  PENDING_REVIEW
  CHANGES_REQUESTED
  APPROVED
  PUBLISHED
  REJECTED
  REMOVED_BY_ADMIN
  SOLD
  ARCHIVED
}

enum MarketplaceItemCondition {
  LIKE_NEW
  VERY_GOOD
  GOOD
  ACCEPTABLE
  HAS_DETAILS
}

enum MarketplaceAssetType {
  IMAGE
  VIDEO
}

enum MarketplaceReviewDecision {
  APPROVE
  REJECT
  REQUEST_CHANGES
  REMOVE
}

enum MarketplaceAppealStatus {
  NONE
  PENDING
  ACCEPTED
  REJECTED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
}

enum MarketplaceOrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
  DISPUTED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PayoutStatus {
  PENDING
  ON_HOLD
  READY_TO_RELEASE
  RELEASED
  CANCELED
}

enum PaymentMethod {
  CASH
  TRANSFER
  MERCADOPAGO
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  passwordHash     String
  firstName        String
  lastName         String
  role             Role       @default(CUSTOMER)
  sellerStatus     SellerStatus @default(NONE)
  isActive         Boolean    @default(true)
  country          String?
  province         String?
  city             String?
  postalCode       String?
  deactivatedAt    DateTime?
  lastLoginAt      DateTime?
  lastSeenAt       DateTime?
  refreshTokenHash String?
  emailVerifiedAt  DateTime?
  emailVerificationTokenHash      String?
  emailVerificationTokenExpiresAt DateTime?
  passwordResetTokenHash          String?
  passwordResetTokenExpiresAt     DateTime?
  cartItems        CartItem[]
  wishlistItems    WishlistItem[]
  productReviews   ProductReview[]
  orders           Order[]
  analyticsEvents  AnalyticsEvent[]
  sellerVerificationRequests SellerVerificationRequest[] @relation("MarketplaceVerificationApplicant")
  marketplaceListings        MarketplaceListing[]         @relation("MarketplaceListingSeller")
  marketplaceReviews         MarketplaceReview[]          @relation("MarketplaceReviewReviewer")
  marketplaceAppeals         MarketplaceAppeal[]          @relation("MarketplaceAppealSeller")
  marketplaceOrdersAsBuyer   MarketplaceOrder[]           @relation("MarketplaceOrderBuyer")
  marketplaceOrdersAsSeller  MarketplaceOrder[]           @relation("MarketplaceOrderSeller")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([emailVerificationTokenHash])
  @@index([passwordResetTokenHash])
  @@index([isActive])
  @@index([lastSeenAt])
  @@index([sellerStatus])
  @@index([country, province, city])
}

model Product {
  id          String      @id @default(uuid())
  title       String
  subtitle    String?
  description String
  author      String
  publisher   String?
  genre       String?
  seriesName  String?
  seriesNumber Int?
  language    String?
  binding     String?
  edition     String?
  translator  String?
  illustrator String?
  narrator    String?
  editor      String?
  originCountry String?
  isbn        String?
  isbn10      String?
  isbn13      String?
  ean         String?
  sku         String      @unique
  type        ProductType
  publicationYear Int?
  publicationDate DateTime?
  pageCount   Int?
  dimensions  String?
  heightCm    Decimal?    @db.Decimal(6, 2)
  widthCm     Decimal?    @db.Decimal(6, 2)
  thicknessCm Decimal?    @db.Decimal(6, 2)
  weightGrams Int?
  conditionLabel String?
  shippingEtaMinDays Int?
  shippingEtaMaxDays Int?
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  coverUrl    String?
  isFeatured  Boolean     @default(false)
  isActive    Boolean     @default(true)
  cartItems   CartItem[]
  wishlistItems WishlistItem[]
  reviews     ProductReview[]
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([title])
  @@index([author])
  @@index([publisher])
  @@index([genre])
  @@index([seriesName])
  @@index([language])
  @@index([binding])
  @@index([conditionLabel])
  @@index([publicationYear])
  @@index([publicationDate])
  @@index([isbn13])
  @@index([ean])
  @@index([type])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model ProductReview {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int
  title     String?
  comment   String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId, createdAt])
  @@index([userId])
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model Order {
  id          String      @id @default(uuid())
  userId      String?
  status      OrderStatus @default(PENDING)
  paymentMethod PaymentMethod?
  shippingProvider   String?
  shippingCity       String?
  shippingPostalCode String?
  shippingCost       Decimal     @default(0) @db.Decimal(10, 2)
  mpPreferenceId      String?
  mpInitPoint         String?
  mpSandboxInitPoint  String?
  mpPaymentId         String?
  mpPaymentStatus     String?
  mpMerchantOrderId   String?
  mpLastWebhookAt     DateTime?
  subtotal    Decimal     @db.Decimal(10, 2)
  discount    Decimal     @db.Decimal(10, 2)
  total       Decimal     @db.Decimal(10, 2)
  couponCode  String?
  notes       String?
  guestEmail     String?
  guestFirstName String?
  guestLastName  String?
  user        User?       @relation(fields: [userId], references: [id], onDelete: Restrict)
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@index([mpPreferenceId])
  @@index([mpPaymentId])
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  productName String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model SellerVerificationRequest {
  id         String                   @id @default(uuid())
  userId     String
  status     SellerVerificationStatus @default(PENDING)
  dniFrontPath String
  dniBackPath  String
  selfiePath   String
  reviewNotes  String?                @db.Text
  reviewedAt   DateTime?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  user       User                     @relation("MarketplaceVerificationApplicant", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model MarketplaceListing {
  id             String                    @id @default(uuid())
  sellerId       String
  status         MarketplaceListingStatus  @default(DRAFT)
  category       MarketplaceListingCategory
  title          String
  subtitle       String?
  description    String                    @db.Text
  author         String?
  publisher      String?
  genre          String?
  language       String?
  edition        String?
  publicationYear Int?
  isbn           String?
  condition      MarketplaceItemCondition
  conditionNotes String?                   @db.Text
  declaredDefects String?                  @db.Text
  price          Decimal                   @db.Decimal(10, 2)
  stock          Int                       @default(1)
  coverAssetId   String?
  adminReason    String?                   @db.Text
  appealStatus   MarketplaceAppealStatus   @default(NONE)
  isActive       Boolean                   @default(false)
  publishedAt    DateTime?
  removedAt      DateTime?
  soldAt         DateTime?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  seller         User                      @relation("MarketplaceListingSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  assets         MarketplaceListingAsset[]
  reviews        MarketplaceReview[]
  appeals        MarketplaceAppeal[]
  orders         MarketplaceOrder[]

  @@index([sellerId])
  @@index([status])
  @@index([isActive])
  @@index([category])
  @@index([publishedAt])
  @@index([createdAt])
}

model MarketplaceListingAsset {
  id         String               @id @default(uuid())
  listingId   String
  type        MarketplaceAssetType
  path        String
  isCover     Boolean              @default(false)
  isEvidence  Boolean              @default(true)
  isApproved  Boolean              @default(false)
  sortOrder   Int                  @default(0)
  createdAt   DateTime             @default(now())
  listing     MarketplaceListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([type])
}

model MarketplaceReview {
  id         String                    @id @default(uuid())
  listingId   String
  reviewerId  String
  decision    MarketplaceReviewDecision
  reason      String
  notes       String?                  @db.Text
  createdAt   DateTime                 @default(now())
  listing     MarketplaceListing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reviewer    User                     @relation("MarketplaceReviewReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)

  @@index([listingId])
  @@index([reviewerId])
  @@index([createdAt])
}

model MarketplaceAppeal {
  id             String                   @id @default(uuid())
  listingId       String
  sellerId        String
  status          MarketplaceAppealStatus @default(PENDING)
  message         String                   @db.Text
  resolutionNotes String?                  @db.Text
  resolvedAt      DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  listing         MarketplaceListing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  seller          User                     @relation("MarketplaceAppealSeller", fields: [sellerId], references: [id], onDelete: Restrict)

  @@index([listingId])
  @@index([sellerId])
  @@index([status])
}

model MarketplaceOrder {
  id               String                 @id @default(uuid())
  buyerId          String
  sellerId         String
  listingId        String
  status           MarketplaceOrderStatus @default(PENDING)
  paymentMethod    PaymentMethod?
  shippingProvider String?
  shippingCity     String?
  shippingPostalCode String?
  shippingCost     Decimal                @default(0) @db.Decimal(10, 2)
  salePrice        Decimal                @db.Decimal(10, 2)
  platformCommission Decimal              @db.Decimal(10, 2)
  sellerNetAmount  Decimal                @db.Decimal(10, 2)
  buyerTotal       Decimal                @db.Decimal(10, 2)
  payoutStatus     PayoutStatus           @default(PENDING)
  mpPreferenceId   String?
  mpInitPoint      String?
  mpSandboxInitPoint String?
  mpPaymentId      String?
  mpPaymentStatus  String?
  deliveredAt      DateTime?
  payoutReleasedAt DateTime?
  disputeOpenedAt  DateTime?
  notes            String?                @db.Text
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  buyer            User                   @relation("MarketplaceOrderBuyer", fields: [buyerId], references: [id], onDelete: Restrict)
  seller           User                   @relation("MarketplaceOrderSeller", fields: [sellerId], references: [id], onDelete: Restrict)
  listing          MarketplaceListing     @relation(fields: [listingId], references: [id], onDelete: Restrict)

  @@index([buyerId])
  @@index([sellerId])
  @@index([listingId])
  @@index([status])
  @@index([payoutStatus])
  @@index([mpPreferenceId])
  @@index([mpPaymentId])
}

model IdempotencyKey {
  id          String   @id @default(uuid())
  scope       String
  key         String
  action      String
  requestHash String
  orderId     String?
  createdAt   DateTime @default(now())

  @@unique([scope, key, action])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String?
  actorRole   String?
  action      String
  entityType  String
  entityId    String?
  requestId   String?
  ip          String?
  userAgent   String?
  meta        Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorUserId])
  @@index([action])
  @@index([entityType])
}

model Coupon {
  id         String       @id @default(uuid())
  code       String       @unique
  discount   Decimal      @db.Decimal(10, 2)
  type       DiscountType
  isActive   Boolean      @default(true)
  startsAt   DateTime?
  expiresAt  DateTime?
  usageLimit Int?
  usedCount  Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model AnalyticsEvent {
  id          String   @id @default(uuid())
  name        String
  path        String?
  anonymousId String?
  sessionId   String?
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  properties  Json?
  createdAt   DateTime @default(now())

  @@index([name])
  @@index([createdAt])
  @@index([userId])
  @@index([anonymousId])
  @@index([sessionId])
}

model SiteContent {
  key       String   @id
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiErrorLog {
  id         String   @id @default(uuid())
  requestId  String
  occurredAt DateTime @default(now())
  method     String
  path       String
  statusCode Int
  message    String
  name       String?
  userId     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([occurredAt])
  @@index([requestId])
  @@index([statusCode])
  @@index([userId])
}
